EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour test-suite"
inherit haskell-cabal

DESCRIPTION="Bindings for AWS General API Version 0.1"
HOMEPAGE="https://github.com/alephcloud/hs-aws-general"
SRC_URI="mirror://hackage/packages/archive/${PN}/${PV}/${P}.tar.gz"

LICENSE="MIT"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="+normalize-signature-v4-date"

RDEPEND=">=dev-haskell/aeson-0.7:=[profile?]
	>=dev-haskell/attoparsec-0.12:=[profile?]
	>=dev-haskell/base16-bytestring-0.1:=[profile?]
	>=dev-haskell/blaze-builder-0.3:=[profile?]
	>=dev-haskell/byteable-0.1:=[profile?]
	>=dev-haskell/case-insensitive-1.2:=[profile?]
	>=dev-haskell/cryptohash-0.11:=[profile?]
	>=dev-haskell/hashable-1.2:=[profile?]
	>=dev-haskell/http-types-0.8:=[profile?]
	>=dev-haskell/old-locale-1.0:=[profile?]
	>=dev-haskell/parsers-0.11:=[profile?]
	>=dev-haskell/quickcheck-2.7:2=[profile?]
	>=dev-haskell/quickcheck-instances-0.3:=[profile?]
	>=dev-haskell/text-1.1:=[profile?]
	>=dev-haskell/transformers-0.3:=[profile?]
	>=dev-lang/ghc-7.6.2:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.18
	test? ( >=dev-haskell/aws-0.9
		>=dev-haskell/charset-0.3
		>=dev-haskell/either-4.3.0
		>=dev-haskell/errors-1.4.7
		>=dev-haskell/parsers-0.12
		>=dev-haskell/tagged-0.7
		>=dev-haskell/tasty-0.8
		>=dev-haskell/tasty-quickcheck-0.8 )
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag normalize-signature-v4-date normalize-signature-v4-date)
}
