EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin lib profile haddock hoogle hscolour"
inherit haskell-cabal

DESCRIPTION="A Windows Installer (MSI) generator framework"
HOMEPAGE="http://hackage.haskell.org/package/bamse"
SRC_URI="mirror://hackage/packages/archive/${PN}/${PV}/${P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="bamsegen build-tests +hsdotnet"

RDEPEND=">=dev-haskell/com-1.2.3:=[profile?]
	dev-haskell/hunit:=[profile?]
	dev-haskell/old-time:=[profile?]
	dev-haskell/quickcheck:2=[profile?]
	dev-haskell/regex-compat:=[profile?]
	>=dev-lang/ghc-7.4.1:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.2
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag bamsegen bamsegen) \
		$(cabal_flag build-tests build-tests) \
		$(cabal_flag hsdotnet hsdotnet)
}
