EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour"
inherit haskell-cabal

MY_PN="OSM"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="Parse OpenStreetMap files"
HOMEPAGE="https://github.com/tonymorris/geo-osm"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="+small_base"

RDEPEND="dev-haskell/comonad-transformers:=[profile?]
	dev-haskell/data-lens:=[profile?]
	>=dev-haskell/hxt-9:=[profile?]
	dev-haskell/newtype:=[profile?]
	>=dev-lang/ghc-7.4.1:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.6
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag small_base small_base)
}
