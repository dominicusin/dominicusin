EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin test-suite"
inherit haskell-cabal

MY_PN="Allure"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="Near-future Sci-Fi roguelike and tactical squad game"
HOMEPAGE="http://allureofthestars.com"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="AGPL-3"
SLOT="0"
KEYWORDS="~amd64 ~x86"
IUSE="+release"

RDEPEND=">=dev-haskell/enummapset-th-0.6.0.0:= <dev-haskell/enummapset-th-1:=
	>=dev-haskell/lambdahack-0.4.100.0:= <dev-haskell/lambdahack-0.5.1.0:=
	>=dev-haskell/text-0.11.2.3:= <dev-haskell/text-2:=
	>=dev-lang/ghc-7.6.1:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.16.0
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag release release)
}
