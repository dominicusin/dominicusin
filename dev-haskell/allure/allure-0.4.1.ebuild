EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin"
inherit haskell-cabal

MY_PN="Allure"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="Near-future roguelike game in early development"
HOMEPAGE="http://github.com/Mikolaj/Allure"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="BSD"
SLOT="0"
KEYWORDS="~amd64 ~x86"
IUSE="curses vty"

RDEPEND=">=dev-haskell/binary-0.4:= <dev-haskell/binary-1:=
	>=dev-haskell/configfile-1.0.6:= <dev-haskell/configfile-2:=
	>=dev-haskell/missingh-1.1.0.3:= <dev-haskell/missingh-1.2:=
	>=dev-haskell/mtl-1.1:= <dev-haskell/mtl-3:=
	dev-haskell/old-time:=
	>=dev-haskell/random-1:= <dev-haskell/random-2:=
	>=dev-haskell/zlib-0.4:= <dev-haskell/zlib-1:=
	>=dev-lang/ghc-7.4.1:=
	curses? ( >=dev-haskell/hscurses-1.3:= <dev-haskell/hscurses-2:=
			unknown-c-lib/curses )
	!curses? ( vty? ( >=dev-haskell/vty-4.4:= )
			!vty? ( >=dev-haskell/gtk-0.11:= <dev-haskell/gtk-0.13:= ) )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.6
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag curses curses) \
		$(cabal_flag vty vty)
}
