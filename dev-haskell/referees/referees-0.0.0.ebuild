EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin lib profile haddock hoogle hscolour"
inherit haskell-cabal

MY_PN="Referees"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="A utility for computing distributions of material to review among reviewers"
HOMEPAGE="https://github.com/pablocouto/Referees"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="GPL-3"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="debug documentation"

RDEPEND=">=dev-haskell/cassava-0.4:=[profile?] <dev-haskell/cassava-0.5:=[profile?]
	>=dev-haskell/cmdargs-0.10:=[profile?] <dev-haskell/cmdargs-0.11:=[profile?]
	>=dev-haskell/cond-0.4:=[profile?] <dev-haskell/cond-0.5:=[profile?]
	>=dev-haskell/glpk-hs-0.3:=[profile?] <dev-haskell/glpk-hs-0.4:=[profile?]
	>=dev-haskell/matrix-0.3:=[profile?] <dev-haskell/matrix-0.4:=[profile?]
	>=dev-haskell/missingh-1.3:=[profile?] <dev-haskell/missingh-1.4:=[profile?]
	>=dev-haskell/vector-0.10:=[profile?] <dev-haskell/vector-0.11:=[profile?]
	>=dev-lang/ghc-7.8.2:=
	documentation? ( >=dev-haskell/hscolour-1.20:=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.18.1.3
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag debug debug) \
		$(cabal_flag documentation documentation)
}
