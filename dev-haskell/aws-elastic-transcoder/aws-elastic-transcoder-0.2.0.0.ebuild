EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin lib profile haddock hoogle hscolour test-suite"
inherit haskell-cabal

DESCRIPTION="Haskell suite for the Elastic Transcoder service"
HOMEPAGE="http://github.com/iconnect/aws-elastic-transcoder"
SRC_URI="mirror://hackage/packages/archive/${PN}/${PV}/${P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="examples"

RDEPEND=">=dev-haskell/aeson-0.6.1:=[profile?]
	>=dev-haskell/aws-0.8.0:=[profile?]
	>=dev-haskell/aws-sign4-0.0.0.1:=[profile?]
	>=dev-haskell/conduit-0.5:=[profile?]
	>=dev-haskell/http-conduit-1.6:=[profile?]
	>=dev-haskell/http-types-0.7:=[profile?]
	>=dev-haskell/quickcheck-2.5.1:2=[profile?]
	>=dev-haskell/regex-compat-0.95:=[profile?]
	>=dev-haskell/safe-0.3.3:=[profile?]
	>=dev-haskell/text-0.11:=[profile?]
	>=dev-haskell/transformers-0.2.2.0:=[profile?]
	>=dev-lang/ghc-7.4.1:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.14
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag examples examples)
}
