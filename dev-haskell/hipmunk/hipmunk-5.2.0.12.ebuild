EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour"
inherit haskell-cabal

MY_PN="Hipmunk"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="A Haskell binding for Chipmunk"
HOMEPAGE="https://github.com/meteficha/Hipmunk"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE=""	# FIXME: Please look at license file of package and pick it manually.
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="debug system-chipmunk"

RDEPEND=">=dev-haskell/statevar-1.0:=[profile?] <dev-haskell/statevar-1.1:=[profile?]
	>=dev-haskell/transformers-0.2:=[profile?] <dev-haskell/transformers-0.4:=[profile?]
	>=dev-lang/ghc-7.4.1:=
	virtual/libc
	system-chipmunk? ( sci-physics/chipmunk )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.6
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag debug debug) \
		$(cabal_flag system-chipmunk system-chipmunk)
}
