	>=dev-haskell/happstack-state-0.5:=[profile?]
	>=dev-haskell/happstack-util-0.5:=[profile?]
	dev-haskell/mtl:=[profile?]
	dev-haskell/utf8-string:=[profile?]
	dev-haskell/xhtml:=[profile?]
	>=dev-lang/ghc-7.4.1:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.2
"

S="${WORKDIR}/${MY_P}"
