	>=dev-haskell/bson-0.2:=[profile?]
	>=dev-haskell/unordered-containers-0.1.3.0:=[profile?]
	>=dev-haskell/vector-0.7.1:=[profile?]
	>=dev-lang/ghc-7.4.1:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.8
	test? ( >=dev-haskell/hspec-1.7.2.1
		>=dev-haskell/hunit-1.2.5.2
		>=dev-haskell/text-0.11.3.1 )
"

S="${WORKDIR}/${MY_P}"
