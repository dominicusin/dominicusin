		dev-haskell/monadrandom
		dev-haskell/random
		>=dev-haskell/test-framework-0.8 <dev-haskell/test-framework-1
		>=dev-haskell/test-framework-hunit-0.2.6
		<dev-haskell/transformers-0.4 )
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag pedantic pedantic)
}
