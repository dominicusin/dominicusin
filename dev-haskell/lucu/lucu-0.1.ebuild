EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin lib profile haddock hoogle hscolour"
inherit haskell-cabal

MY_PN="Lucu"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="HTTP Daemonic Library"
HOMEPAGE="http://cielonegro.org/Lucu.html"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="public-domain"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="+build-lucu-implant-file"

RDEPEND="dev-haskell/dataenc:=[profile?]
	dev-haskell/haskell-src:=[profile?]
	dev-haskell/hsopenssl:=[profile?]
	dev-haskell/hxt:=[profile?]
	dev-haskell/mtl:=[profile?]
	dev-haskell/network:=[profile?]
	dev-haskell/stm:=[profile?]
	dev-haskell/zlib:=[profile?]
	>=dev-lang/ghc-7.4.1:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.2
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag build-lucu-implant-file build-lucu-implant-file)
}
