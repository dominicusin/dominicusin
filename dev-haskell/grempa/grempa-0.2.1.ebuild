EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour"
inherit haskell-cabal

MY_PN="Grempa"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="Embedded grammar DSL and LALR parser generator"
HOMEPAGE="http://hackage.haskell.org/package/Grempa"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="+test"

RDEPEND=">=dev-haskell/mtl-2.0:=[profile?] <dev-haskell/mtl-2.1:=[profile?]
	>=dev-haskell/th-lift-0.5:=[profile?] <dev-haskell/th-lift-0.6:=[profile?]
	>=dev-lang/ghc-7.4.1:=
	test? ( >=dev-haskell/quickcheck-2.4:2=[profile?] <dev-haskell/quickcheck-2.5:2=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.6
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag test test)
}
