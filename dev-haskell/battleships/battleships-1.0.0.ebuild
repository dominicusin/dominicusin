EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin lib profile haddock hoogle hscolour"
inherit haskell-cabal

DESCRIPTION="A web-based implementation of battleships including an AI opponent"
HOMEPAGE="https://github.com/zrho/afp"
SRC_URI="mirror://hackage/packages/archive/${PN}/${PV}/${P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="dev library-only"

RDEPEND="dev-haskell/aeson:=[profile?]
	dev-haskell/attoparsec:=[profile?]
	dev-haskell/base64-bytestring:=[profile?]
	dev-haskell/blaze-svg:=[profile?]
	dev-haskell/cereal:=[profile?]
	dev-haskell/colour:=[profile?]
	dev-haskell/cookie:=[profile?]
	dev-haskell/crypto-random:=[profile?]
	dev-haskell/data-default:=[profile?]
	dev-haskell/diagrams-lib:=[profile?]
	dev-haskell/diagrams-svg:=[profile?]
	>=dev-haskell/fast-logger-0.3.2:=[profile?]
	>=dev-haskell/hamlet-1.1:=[profile?] <dev-haskell/hamlet-1.2:=[profile?]
	dev-haskell/hjsmin:=[profile?]
	dev-haskell/monadrandom:=[profile?]
	dev-haskell/mtl:=[profile?]
	dev-haskell/shakespeare-js:=[profile?]
	>=dev-haskell/shakespeare-text-1.0:=[profile?] <dev-haskell/shakespeare-text-1.1:=[profile?]
	dev-haskell/simpleaes:=[profile?]
	>=dev-haskell/text-0.11:=[profile?] <dev-haskell/text-0.12:=[profile?]
	dev-haskell/transformers:=[profile?]
	dev-haskell/wai-extra:=[profile?]
	dev-haskell/wai-logger:=[profile?]
	dev-haskell/word8:=[profile?]
	dev-haskell/yaml:=[profile?]
	>=dev-haskell/yesod-1.2:=[profile?] <dev-haskell/yesod-1.2.5:=[profile?]
	>=dev-haskell/yesod-core-1.2:=[profile?] <dev-haskell/yesod-core-1.3:=[profile?]
	dev-haskell/yesod-routes:=[profile?]
	>=dev-haskell/yesod-static-1.2:=[profile?] <dev-haskell/yesod-static-1.3:=[profile?]
	>=dev-lang/ghc-7.4.1:=
	dev? ( dev-haskell/warp:=[profile?] )
	!dev? ( >=dev-haskell/wai-handler-fastcgi-1.3:=[profile?] <dev-haskell/wai-handler-fastcgi-2.1:=[profile?]
		library-only? ( dev-haskell/warp:=[profile?] ) )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.8
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag dev dev) \
		$(cabal_flag library-only library-only)
}
