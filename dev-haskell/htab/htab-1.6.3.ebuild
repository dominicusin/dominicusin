EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin"
inherit haskell-cabal

MY_PN="HTab"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="Tableau based theorem prover for hybrid logics"
HOMEPAGE="http://www.glyc.dc.uba.ar/intohylo/htab.php"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64 ~x86"
IUSE="static"

RDEPEND=">=dev-haskell/cmdargs-0.10.1:=
	>=dev-haskell/hylolib-1.4:= <dev-haskell/hylolib-1.5:=
	>=dev-haskell/mtl-2:= <dev-haskell/mtl-3:=
	dev-haskell/strict:=
	>=dev-lang/ghc-7.4.1:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.6.0
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag static static)
}
