EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin lib profile haddock hoogle hscolour"
inherit haskell-cabal

DESCRIPTION="Interchange with the Audacity sound signal editor"
HOMEPAGE="http://code.haskell.org/~thielema/audacity"
SRC_URI="mirror://hackage/packages/archive/${PN}/${PV}/${P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="buildexamples"

RDEPEND=">=dev-haskell/utility-ht-0.0.10:=[profile?] <dev-haskell/utility-ht-0.1:=[profile?]
	>=dev-lang/ghc-7.4.1:=
	buildexamples? ( >=dev-haskell/non-empty-0.1.3:=[profile?] <dev-haskell/non-empty-0.3:=[profile?]
				>=dev-haskell/soxlib-0.0:=[profile?] <dev-haskell/soxlib-0.1:=[profile?]
				>=dev-haskell/storablevector-0.2.9:=[profile?] <dev-haskell/storablevector-0.3:=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.10
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag buildexamples buildexamples)
}
