EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour"
inherit haskell-cabal

MY_PN="HGamer3D"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="A Game Engine for the Haskell Programmer"
HOMEPAGE="http://www.hgamer3d.org"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE=""	# FIXME: Please look at license file of package and pick it manually.
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="+audio +inputsystem +network"

RDEPEND="dev-haskell/clock:=[profile?]
	dev-haskell/hashable:=[profile?]
	dev-haskell/hashtables:=[profile?]
	>=dev-haskell/hgamer3d-data-0.4.0:=[profile?] <dev-haskell/hgamer3d-data-0.5.0:=[profile?]
	>=dev-haskell/hgamer3d-graphics3d-0.4.0:=[profile?] <dev-haskell/hgamer3d-graphics3d-0.5.0:=[profile?]
	>=dev-haskell/hgamer3d-gui-0.4.0:=[profile?] <dev-haskell/hgamer3d-gui-0.5.0:=[profile?]
	>=dev-haskell/hgamer3d-winevent-0.4.0:=[profile?] <dev-haskell/hgamer3d-winevent-0.5.0:=[profile?]
	dev-haskell/split:=[profile?]
	>=dev-lang/ghc-7.4.1:=
	audio? ( >=dev-haskell/hgamer3d-audio-0.4:=[profile?] <dev-haskell/hgamer3d-audio-0.5:=[profile?] )
	inputsystem? ( >=dev-haskell/hgamer3d-inputsystem-0.4:=[profile?] <dev-haskell/hgamer3d-inputsystem-0.5:=[profile?] )
	network? ( >=dev-haskell/hgamer3d-network-0.4:=[profile?] <dev-haskell/hgamer3d-network-0.5:=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.4
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag audio audio) \
		$(cabal_flag inputsystem inputsystem) \
		$(cabal_flag network network)
}
