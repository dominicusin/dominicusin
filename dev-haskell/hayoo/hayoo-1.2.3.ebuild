EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin"
inherit haskell-cabal

MY_PN="Hayoo"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="The Hayoo! search engine for Haskell API search on hackage"
HOMEPAGE="http://holumbus.fh-wedel.de"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="MIT"
SLOT="0"
KEYWORDS="~amd64 ~x86"
IUSE="hashedindex +hayoosnap4"

RDEPEND=">=dev-haskell/binary-0.5:= <dev-haskell/binary-1:=
	>=dev-haskell/bzlib-0.4:= <dev-haskell/bzlib-1:=
	>=dev-haskell/enummapset-0:= <dev-haskell/enummapset-1:=
	>=dev-haskell/holumbus-searchengine-1.2.3:= <dev-haskell/holumbus-searchengine-2:=
	>=dev-haskell/hxt-9.1:= <dev-haskell/hxt-10:=
	>=dev-haskell/hxt-cache-9:= <dev-haskell/hxt-cache-10:=
	>=dev-haskell/hxt-charproperties-9:= <dev-haskell/hxt-charproperties-10:=
	>=dev-haskell/hxt-curl-9:= <dev-haskell/hxt-curl-10:=
	>=dev-haskell/hxt-http-9:= <dev-haskell/hxt-http-10:=
	>=dev-haskell/hxt-regex-xmlschema-9:= <dev-haskell/hxt-regex-xmlschema-10:=
	>=dev-haskell/hxt-unicode-9:= <dev-haskell/hxt-unicode-10:=
	>=dev-haskell/hxt-xpath-9.1:= <dev-haskell/hxt-xpath-10:=
	>=dev-haskell/json-0.4:= <dev-haskell/json-1:=
	>=dev-haskell/monadcatchio-transformers-0.2.1:= <dev-haskell/monadcatchio-transformers-0.3:=
	>=dev-haskell/mtl-2:= <dev-haskell/mtl-3:=
	>=dev-haskell/network-2.1:= <dev-haskell/network-3:=
	>=dev-haskell/old-time-1:= <dev-haskell/old-time-2:=
	>=dev-haskell/parsec-2.1:= <dev-haskell/parsec-4:=
	>=dev-haskell/tar-0.3:= <dev-haskell/tar-1:=
	>=dev-haskell/text-0.11:= <dev-haskell/text-1:=
	>=dev-haskell/transformers-0.2.2:= <dev-haskell/transformers-0.3:=
	>=dev-haskell/xhtml-combinators-0.2.2:= <dev-haskell/xhtml-combinators-0.3:=
	>=dev-haskell/zlib-0.5:= <dev-haskell/zlib-1:=
	>=dev-lang/ghc-7.4.1:=
	hayoosnap4? ( >=dev-haskell/snap-0.4:= <dev-haskell/snap-0.6:=
			>=dev-haskell/snap-core-0.4:= <dev-haskell/snap-core-0.6:=
			>=dev-haskell/snap-server-0.4:= <dev-haskell/snap-server-0.6:= )
	!hayoosnap4? ( >=dev-haskell/data-lens-2:=
			>=dev-haskell/data-lens-template-2.1:= <dev-haskell/data-lens-template-2.2:=
			>=dev-haskell/heist-0.7:= <dev-haskell/heist-0.9:=
			>=dev-haskell/snap-0.7:= <dev-haskell/snap-0.8:=
			>=dev-haskell/snap-core-0.7:= <dev-haskell/snap-core-0.8:=
			>=dev-haskell/snap-server-0.7:= <dev-haskell/snap-server-0.8:= )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.6
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag hashedindex hashedindex) \
		$(cabal_flag hayoosnap4 hayoosnap4)
}
