EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin lib profile haddock hoogle hscolour test-suite"
inherit haskell-cabal

MY_PN="ActionKid"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="An easy-to-use video game framework for Haskell"
HOMEPAGE="https://github.com/egonSchiele/actionkid"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE=""

RDEPEND="dev-haskell/gloss:=[profile?]
	dev-haskell/gloss-juicy:=[profile?]
	dev-haskell/lens:=[profile?]
	dev-haskell/mtl:=[profile?]
	>=dev-haskell/opengl-2.8.0:=[profile?] <dev-haskell/opengl-2.10:=[profile?]
	dev-haskell/statevar:=[profile?]
	>=dev-lang/ghc-7.6.1:=
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.16.0
	test? ( dev-haskell/hspec )
"

S="${WORKDIR}/${MY_P}"
