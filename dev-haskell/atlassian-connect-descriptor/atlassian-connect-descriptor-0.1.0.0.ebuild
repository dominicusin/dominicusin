IUSE="+network-uri"

RDEPEND=">dev-haskell/aeson-0.7.0.3:=[profile?] <dev-haskell/aeson-0.8:=[profile?]
	>=dev-haskell/cases-0.1:=[profile?] <dev-haskell/cases-0.2:=[profile?]
	>=dev-haskell/text-0.11:=[profile?] <=dev-haskell/text-1.2:=[profile?]
	>=dev-haskell/time-units-1:=[profile?] <dev-haskell/time-units-2:=[profile?]
	>=dev-haskell/unordered-containers-0.2:=[profile?] <dev-haskell/unordered-containers-0.3:=[profile?]
	>=dev-lang/ghc-7.6.1:=
	network-uri? ( >=dev-haskell/network-2.6:=[profile?]
			>=dev-haskell/network-uri-2.6:=[profile?] )
	!network-uri? ( <dev-haskell/network-2.6:=[profile?]
			<dev-haskell/network-uri-2.6:=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.20
	test? ( dev-haskell/hunit
		dev-haskell/scientific
		dev-haskell/vector )
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag network-uri network-uri)
}
