EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour test-suite"
inherit haskell-cabal

MY_PN="Omega"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="Integer sets and relations using Presburger arithmetic"
HOMEPAGE="http://hackage.haskell.org/package/Omega"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="useinstalledomega"

RDEPEND=">=dev-lang/ghc-7.4.1:=
	sys-devel/gcc[cxx]
	useinstalledomega? ( unknown-c-lib/omega )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.9.2
	test? ( dev-haskell/hunit )
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag useinstalledomega useinstalledomega)
}
