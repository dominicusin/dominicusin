EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin"
inherit haskell-cabal

MY_PN="YampaSynth"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="Software synthesizer"
HOMEPAGE="http://www.cs.nott.ac.uk/~ggg/"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="BSD"
SLOT="0"
KEYWORDS="~amd64 ~x86"
IUSE="+gtk +openal +wav"

RDEPEND=">=dev-lang/ghc-7.4.1:=
	gtk? ( dev-haskell/glade:=
		dev-haskell/gtk:=
		dev-haskell/hcodecs:=
		dev-haskell/openal:=
		dev-haskell/yampa:= )
	openal? ( dev-haskell/hcodecs:=
			dev-haskell/openal:=
			dev-haskell/yampa:= )
	wav? ( dev-haskell/hcodecs:=
		dev-haskell/yampa:= )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.2
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag gtk gtk) \
		$(cabal_flag openal openal) \
		$(cabal_flag wav wav)
}
