CABAL_FEATURES="lib profile haddock hoogle hscolour"
inherit haskell-cabal

MY_PN="Genbank"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="Libary for processing the NCBI genbank format"
HOMEPAGE="http://hackage.haskell.org/package/Genbank"
