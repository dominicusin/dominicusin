EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour"
inherit haskell-cabal

DESCRIPTION="An embedded language for accelerated array processing"
HOMEPAGE="http://www.cse.unsw.edu.au/~chak/project/accelerate/"
SRC_URI="mirror://hackage/packages/archive/${PN}/${PV}/${P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="+bounds-checks +cuda inplace internal-checks io llvm more-pp pcache test-suite unsafe-checks"

RDEPEND=">=dev-haskell/mtl-2.0:=[profile?] <dev-haskell/mtl-2.1:=[profile?]
	>=dev-lang/ghc-7.4.1:=
	cuda? ( >=dev-haskell/binary-0.5:=[profile?] <dev-haskell/binary-0.6:=[profile?]
		>=dev-haskell/cuda-0.2.2:=[profile?]
		>=dev-haskell/fclabels-1.0:=[profile?] <dev-haskell/fclabels-1.2:=[profile?]
		>=dev-haskell/language-c-0.3:=[profile?] <dev-haskell/language-c-0.5:=[profile?]
		>=dev-haskell/transformers-0.2:=[profile?] <dev-haskell/transformers-0.3:=[profile?]
		>=dev-haskell/zlib-0.5:=[profile?] <dev-haskell/zlib-0.5.3.2:=[profile?] )
	llvm? ( >=dev-haskell/llvm-0.6.8:=[profile?] )
	more-pp? ( >=dev-haskell/blaze-html-0.3:=[profile?] <dev-haskell/blaze-html-0.4:=[profile?]
			>=dev-haskell/text-0.10:=[profile?] <dev-haskell/text-0.11:=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.6
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag bounds-checks bounds-checks) \
		$(cabal_flag cuda cuda) \
		$(cabal_flag inplace inplace) \
		$(cabal_flag internal-checks internal-checks) \
		$(cabal_flag io io) \
		$(cabal_flag llvm llvm) \
		$(cabal_flag more-pp more-pp) \
		$(cabal_flag pcache pcache) \
		$(cabal_flag test-suite test-suite) \
		$(cabal_flag unsafe-checks unsafe-checks)
}
