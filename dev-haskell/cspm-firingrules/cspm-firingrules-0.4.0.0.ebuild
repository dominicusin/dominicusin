EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour"
inherit haskell-cabal

MY_PN="CSPM-FiringRules"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="Firing rules semantic of CSPM"
HOMEPAGE="http://hackage.haskell.org/package/CSPM-FiringRules"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="+quickcheck"

RDEPEND=">=dev-haskell/cspm-corelanguage-0.3:=[profile?] <dev-haskell/cspm-corelanguage-0.4:=[profile?]
	>=dev-haskell/parallel-tree-search-0.4:=[profile?] <dev-haskell/parallel-tree-search-0.5:=[profile?]
	>=dev-haskell/tree-monad-0.3:=[profile?] <dev-haskell/tree-monad-0.4:=[profile?]
	>=dev-lang/ghc-7.4.1:=
	|| ( ( >=dev-haskell/mtl-1.1:=[profile?] <dev-haskell/mtl-1.2:=[profile?] )
		( >=dev-haskell/mtl-2.0:=[profile?] <dev-haskell/mtl-2.1:=[profile?] ) )
	quickcheck? ( >=dev-haskell/quickcheck-2.4:2=[profile?] <dev-haskell/quickcheck-2.5:2=[profile?]
			>=dev-haskell/random-1.0:=[profile?] <dev-haskell/random-1.1:=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.10
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag quickcheck quickcheck)
}
