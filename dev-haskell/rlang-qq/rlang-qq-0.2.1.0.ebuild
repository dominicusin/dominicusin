EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour test-suite"
inherit haskell-cabal

MY_PN="Rlang-QQ"
MY_P="${MY_PN}-${PV}"

DESCRIPTION="quasiquoter for inline-R code"
HOMEPAGE="http://code.haskell.org/~aavogt/Rlang-QQ"
SRC_URI="mirror://hackage/packages/archive/${MY_PN}/${PV}/${MY_P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="+repa"

RDEPEND="dev-haskell/binary:=[profile?]
	dev-haskell/cabal:=[profile?]
	dev-haskell/haskell-src-meta:=[profile?]
	>=dev-haskell/hlist-0.3.4:=[profile?]
	dev-haskell/mtl:=[profile?]
	dev-haskell/split:=[profile?]
	dev-haskell/syb:=[profile?]
	dev-haskell/temporary:=[profile?]
	dev-haskell/text:=[profile?]
	dev-haskell/transformers:=[profile?]
	>=dev-haskell/trifecta-1.4:=[profile?]
	>=dev-haskell/utf8-string-0.3:=[profile?] <dev-haskell/utf8-string-0.4:=[profile?]
	dev-haskell/vector:=[profile?]
	dev-haskell/zlib:=[profile?]
	>=dev-lang/ghc-7.4.1:=
	repa? ( dev-haskell/repa:=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.10
	test? ( >=dev-haskell/doctest-0.8 )
"

S="${WORKDIR}/${MY_P}"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag repa repa)
}
