	>=dev-haskell/criterion-0.5:= <dev-haskell/criterion-0.9:=
	>=dev-haskell/fclabels-1.0:= <dev-haskell/fclabels-1.2:=
	>=dev-haskell/gloss-1.7:= <dev-haskell/gloss-1.8:=
