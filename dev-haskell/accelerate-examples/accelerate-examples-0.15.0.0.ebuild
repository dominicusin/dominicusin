EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin"
inherit haskell-cabal

DESCRIPTION="Examples using the Accelerate library"
HOMEPAGE="https://github.com/AccelerateHS/accelerate-examples"
SRC_URI="mirror://hackage/packages/archive/${PN}/${PV}/${P}.tar.gz"

LICENSE="BSD"
SLOT="0"
KEYWORDS="~amd64 ~x86"
IUSE="+cuda +ekg +gui +llvm-cpu +llvm-gpu +llvm-multi opencl"

RDEPEND=">=dev-lang/ghc-7.4.1:=
	cuda? ( >=dev-haskell/accelerate-cuda-0.15:= <dev-haskell/accelerate-cuda-0.16:= )
	ekg? ( >=dev-haskell/ekg-0.3:= )
	llvm-cpu? ( dev-haskell/accelerate-llvm:=
			>=dev-haskell/accelerate-llvm-native-0.15:= <dev-haskell/accelerate-llvm-native-0.16:=
			llvm-gpu? ( llvm-multi? ( >=dev-haskell/accelerate-llvm-multidev-0.15:= <dev-haskell/accelerate-llvm-multidev-0.16:= ) ) )
	llvm-gpu? ( >=dev-haskell/accelerate-llvm-ptx-0.15:= <dev-haskell/accelerate-llvm-ptx-0.16:= )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.6
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag cuda cuda) \
		$(cabal_flag ekg ekg) \
		$(cabal_flag gui gui) \
		$(cabal_flag llvm-cpu llvm-cpu) \
		$(cabal_flag llvm-gpu llvm-gpu) \
		$(cabal_flag llvm-multi llvm-multi) \
		$(cabal_flag opencl opencl)
}
