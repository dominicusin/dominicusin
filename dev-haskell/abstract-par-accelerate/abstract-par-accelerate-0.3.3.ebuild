EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="lib profile haddock hoogle hscolour"
inherit haskell-cabal

DESCRIPTION="Provides the class ParAccelerate, nothing more"
HOMEPAGE="https://github.com/simonmar/monad-par"
SRC_URI="mirror://hackage/packages/archive/${PN}/${PV}/${P}.tar.gz"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64 ~x86"
IUSE="io +newaccelerate"

RDEPEND=">=dev-haskell/abstract-par-0.3:=[profile?]
	>=dev-haskell/vector-0.9:=[profile?]
	>=dev-lang/ghc-7.4.1:=
	io? ( newaccelerate? ( >=dev-haskell/accelerate-io-0.12:=[profile?] ) )
	newaccelerate? ( >=dev-haskell/accelerate-0.12:=[profile?] )
	!newaccelerate? ( >=dev-haskell/accelerate-0.10:=[profile?] <dev-haskell/accelerate-0.12:=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.8
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag io io) \
		$(cabal_flag newaccelerate newaccelerate)
}
