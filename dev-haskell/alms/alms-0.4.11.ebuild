EAPI=5

# ebuild generated by hackport 0.4.5

CABAL_FEATURES="bin"
inherit haskell-cabal

DESCRIPTION="a practical affine language"
HOMEPAGE="http://www.ccs.neu.edu/~tov/pubs/alms"
SRC_URI="mirror://hackage/packages/archive/${PN}/${PV}/${P}.tar.gz"

LICENSE="BSD"
SLOT="0"
KEYWORDS="~amd64 ~x86"
IUSE="+editline readline"

RDEPEND=">=dev-haskell/hunit-1.2:=
	>=dev-haskell/mtl-1.1:=
	>=dev-haskell/network-2.2:=
	>=dev-haskell/parsec-2:= <dev-haskell/parsec-3:=
	>=dev-haskell/quickcheck-2:2=
	>=dev-haskell/random-1:=
	>=dev-haskell/syb-0.1:=
	>=dev-lang/ghc-7.4.1:=
	editline? ( !readline? ( >=dev-haskell/editline-0.2.1:= ) )
	readline? ( >=dev-haskell/readline-1.0:= )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-1.8
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag editline editline) \
		$(cabal_flag readline readline)
}
